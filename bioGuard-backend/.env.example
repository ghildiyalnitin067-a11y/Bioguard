# ─── Required ────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bioguard?retryWrites=true&w=majority&appName=<appName>
JWT_SECRET=some_long_random_secret_string_here

# ─── CORS ────────────────────────────────────────────────────
# Set this to your deployed frontend URL (Vercel / Netlify / etc.)
FRONTEND_URL=https://your-frontend-url.vercel.app

# ─── Email Notifications (optional) ─────────────────────────
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASS=your_16_char_app_password

# ─── Google OAuth (optional) ─────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
